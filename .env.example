# E-Commerce Backend Environment Variables
# Copy this file to .env and update the values

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Rate limiting
# In development the API limiter is disabled by default.
# Set RATE_LIMIT_ENABLED=true to test rate limiting locally.
RATE_LIMIT_ENABLED=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SUBSCRIBE_RATE_LIMIT_WINDOW_MS=3600000
SUBSCRIBE_RATE_LIMIT_MAX_REQUESTS=5

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ecommerce

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin User (Optional - for seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# Payment Gateway (Optional - for future integration)
STRIPE_API_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# Email Service (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# AWS S3 (Optional - for image uploads)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1
